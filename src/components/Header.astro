---
import InstagramIcon from '@lucide/astro/icons/instagram';
import MicIcon from '@lucide/astro/icons/mic-vocal';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="fixed top-6 left-0 right-0 z-50 px-6">
	<nav class="max-w-5xl mx-auto overflow-hidden rounded-2xl border border-white/10 relative">
		<!-- Glass Layer -->
		<div class="absolute inset-0 bg-gradient-to-r from-red-950/40 via-black/90 to-red-950/40 backdrop-blur-2xl -z-10"></div>
		
		<div class="px-6 py-4 flex items-center justify-between">
			<div class="flex items-center gap-2">
				<MicIcon class="w-6 h-6 text-red-500" />
				<HeaderLink href="/" class="font-bold tracking-tighter text-xl uppercase">{SITE_TITLE}<span class="text-red-600">.</span></HeaderLink>
			</div>
			
			<ul class="hidden md:flex gap-8">
				<li><HeaderLink href="/#services" class="text-xs uppercase tracking-widest font-semibold text-gray-400 hover:text-red-500 transition-colors">Services</HeaderLink></li>
				<li><HeaderLink href="/#projects" class="text-xs uppercase tracking-widest font-semibold text-gray-400 hover:text-red-500 transition-colors">Projects</HeaderLink></li>
				<li><HeaderLink href="/#reach" class="text-xs uppercase tracking-widest font-semibold text-gray-400 hover:text-red-500 transition-colors">Reach</HeaderLink></li>
				<li><HeaderLink href="/#contact" class="text-xs uppercase tracking-widest font-semibold text-gray-400 hover:text-red-500 transition-colors">Contact</HeaderLink></li>
				<li><HeaderLink href="/blog" class="text-xs uppercase tracking-widest font-semibold text-gray-400 hover:text-red-500 transition-colors">Blog</HeaderLink></li>
			</ul>

			<div class="flex items-center gap-4">
				<a href="https://instagram.com/tallescattarin" target="_blank" class="text-gray-400 hover:text-white transition-colors">
					<InstagramIcon class="w-5 h-5" />
				</a>
				<HeaderLink href="/#contact" class="bg-red-600 hover:bg-red-700 text-white px-4 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wider transition-all shadow-lg shadow-red-900/20">
					Hire Me
				</HeaderLink>
			</div>
		</div>
	</nav>
</header>
