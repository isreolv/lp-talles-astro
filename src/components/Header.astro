---
import InstagramIcon from '@lucide/astro/icons/instagram';
import { SITE_TITLE } from '../consts';
import tallesLogoSm from '../assets/talles-logo-sm.svg';
import HeaderLink from './HeaderLink.astro';
---

<header class="fixed top-4 left-0 right-0 z-50 px-6">
	<nav class="max-w-7xl mx-auto overflow-hidden rounded-lg border border-white/10 relative bg-[#0D0D0D] [border-image-source:linear-gradient(0deg,#191919,#191919),linear-gradient(90.21deg,rgba(255,255,255,0)_88.75%,rgba(255,255,255,0.32)_100%)] [border-image-slice:1]">
		<!-- Glass Layer
		<div class="absolute inset-0 bg-gradient-to-r from-red-950/40 via-black/90 to-red-950/40 backdrop-blur-2xl -z-10"></div> -->
		
		<div class="h-16 px-6 py-4 flex items-center justify-between">
			<HeaderLink href="/" class="font-bold tracking-tighter text-xl uppercase transition-transform duration-300 hover:scale-110">
				<img src={tallesLogoSm.src} alt={SITE_TITLE} class="h-8" />
			</HeaderLink>
			
			<ul class="hidden md:flex gap-8">
				<li><HeaderLink href="/#home" class="text-sm uppercase tracking-widest font-light text-gray-400 hover:text-red-500 transition-colors">Home</HeaderLink></li>
				<li><HeaderLink href="/#about" class="text-sm uppercase tracking-widest font-light text-gray-400 hover:text-red-500 transition-colors">About</HeaderLink></li>
				<li><HeaderLink href="/#productions" class="text-sm uppercase tracking-widest font-light text-gray-400 hover:text-red-500 transition-colors">Productions</HeaderLink></li>
				<li><HeaderLink href="/blog" class="text-sm uppercase tracking-widest font-light text-gray-400 hover:text-red-500 transition-colors">Blog</HeaderLink></li>
			</ul>

			<div class="flex items-center gap-4">
				<!-- <a href="https://instagram.com/tallescattarin" target="_blank" class="text-gray-400 hover:text-white transition-colors">
					<InstagramIcon class="w-5 h-5" />
				</a>
				<HeaderLink href="/#contact" class="bg-red-600 hover:bg-red-700 text-white px-4 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wider transition-all shadow-lg shadow-red-900/20">
					Hire Me
				</HeaderLink> -->
			</div>
		</div>
	</nav>
</header>
