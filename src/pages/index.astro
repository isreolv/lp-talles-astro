					</div>

					<div class="top-34 z-30 sticky grid md:grid-cols-2 bg-black p-6 rounded-2xl w-full h-120">
						<div class="flex flex-col gap-8 col-span-1 px-8 py-6 rounded-3xl">
							<h3 class="font-semibold text-2xl uppercase">High-Quality <br />Mastering</h3>
							
