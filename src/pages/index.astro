---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import {
	SITE_DESCRIPTION,
	SITE_TITLE,
	CONTACT_WHATSAPP,
	SOCIAL_INSTAGRAM,
	SOCIAL_YOUTUBE,
	SOCIAL_TIKTOK,
	SOCIAL_YOUTUBE_MUSIC,
	SOCIAL_SPOTIFY,
	SOCIAL_DEEZER,
	SOCIAL_APPLE_MUSIC,
	SOCIAL_AMAZON_MUSIC,
	SOCIAL_AIRBIT,
	SOCIAL_FIVERR,
} from '../consts';

import AudioLinesIcon from '@lucide/astro/icons/audio-lines';
import tallesHeroSvg from '../assets/tcbrand.svg';

import tallesPic from '../assets/talles.webp';
import tallesProduction from '../assets/production.png';
import tallesMnm from '../assets/mnm.png';
import tallesVocals from '../assets/vocals.png';
import coverSong1 from '../assets/same-mistake.png'
import coverSong2 from '../assets/fate-of-ophelia.png'
import coverSong3 from '../assets/game-of-thrones.png'
import coverSong4 from '../assets/wicked-game.png'
import { ArrowRight } from '@lucide/astro';

// Generate Waveform Bars Array at build time
const numBars = 30;
const bars = Array.from({ length: numBars }).map((_, i) => {
    const initialScale = 0.3 + Math.random() * 0.4;
    const maxScale = 0.7 + Math.random() * 0.3;
    return {
        randomDelay: Math.random() * -3,
        duration: 1.5 + Math.random() * 1.5,
        staggerDelay: i * 0.04,
        initialScale,
        maxScale
    };
});
---


<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style is:global>
            @keyframes eq-pulse {
                0%, 100% { transform: scaleY(var(--start-scale)); }
                50% { transform: scaleY(var(--max-scale)); }
            }
            .animate-eq {
                animation: eq-pulse var(--anim-duration) ease-in-out infinite;
            }

			@keyframes mini-eq-pulse {
				0%, 100% { transform: scaleY(0.5); }
				50% { transform: scaleY(1.3); }
			}

			.eq-line {
				transform-origin: center;
				transform-box: fill-box;
				animation: mini-eq-pulse var(--dur) ease-in-out var(--delay) infinite;
			}
        </style>
    </head>
    <body class="bg-[#030303] selection:bg-red-600 selection:text-white antialiased">
        
        <div id="delayed-header" class="z-50 relative opacity-0 transition-opacity duration-700 ease-out pointer-events-none">
            <Header />
        </div>

        <main>
            <section id="home" class="relative min-h-screen overflow-hidden hero-bg">
                
                <div class="z-40 absolute inset-0 overflow-hidden pointer-events-none mix-blend-color-dodge">
                    <div 
                        id="three-container"
                        class="relative opacity-0 w-full h-full scale-95 origin-top-right transition-all duration-0"
                    ></div>
                </div>

                <div class="relative flex flex-col mx-auto px-6 xl:px-0 py-16 max-w-7xl h-screen">
                    <div class="z-30 flex flex-col justify-center items-center gap-8 h-full">
                        <p class="top-56 z-0 absolute font-gothic text-white/5 lg:text-[9rem] text-xl text-xl tracking-widest hero-title">
                            Talles Cattarin
                        </p>

                        <div id="delayed-badge" class="inline-flex z-10 justify-center items-center space-x-4 bg-zinc-950 opacity-0 px-3 py-2 border border-[#1C1C1C] rounded-[40px] text-white/80 transition-opacity duration-700 pointer-events-none">
                            <AudioLinesIcon class="w-5 h-5 text-red-500" />
                            <p class="hidden md:block">Music Producer, Singer and Audio Engineer</p>
                            <p class="md:hidden">Musician and Music Producer</p>
                        </div>

                        <img 
							id="hero-logo" 
							src={tallesHeroSvg.src} 
							class="z-10 brightness-5 mt-4 w-full max-w-2xl -rotate-2 hover:rotate-0 scale-[0.98] transition-all" 
							alt="Talles Cattarin" 
						/>

                        <div class="flex justify-center items-center gap-[4px] mt-8 md:mt-12 w-full max-w-md h-[24px]">
                            {bars.map((bar) => (
                                <div
                                    class="bg-white/[0.32] opacity-0 rounded-full w-[2px] transition-all duration-500 ease-out wave-bar"
                                    style={`
                                        height: 100%; 
                                        transform: scaleY(${bar.initialScale});
                                        transition-delay: ${bar.staggerDelay}s;
                                        animation-delay: ${bar.randomDelay}s;
                                        --start-scale: ${bar.initialScale};
                                        --max-scale: ${bar.maxScale};
                                        --anim-duration: ${bar.duration}s;
                                    `}
                                />
                            ))}
                        </div>
                    </div>

                    <div class="z-30 flex md:flex-row flex-col-reverse md:justify-between items-end gap-4 w-full">
                        <p id="delayed-text" class="z-10 opacity-0 max-w-2xl font-light text-gray-400 text-xs md:text-sm uppercase leading-relaxed tracking-wide transition-opacity duration-700 pointer-events-none">
                            Crafting sonic  · Building cultural
                        </p>
                        <div id="delayed-buttons" class="flex flex-col items-end gap-4 opacity-0 transition-opacity duration-700 pointer-events-none">
                            <a href="#portfolio" class="inline-flex items-center gap-2 bg-[#EC003F] hover:brightness-110 px-4 py-2.5 rounded-4xl hover:scale-102 transition-all duration-300 hover:cursor-pointer">
                                <svg width="12" height="14" viewBox="0 0 12 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M11.394 7.79602L1.8495 13.334C1.0395 13.8035 0 13.235 0 12.2885V1.21252C0 0.267522 1.038 -0.302478 1.8495 0.168522L11.394 5.70652C11.5783 5.81171 11.7314 5.96375 11.8379 6.14723C11.9445 6.33071 12.0006 6.53911 12.0006 6.75127C12.0006 6.96344 11.9445 7.17183 11.8379 7.35531C11.7314 7.53879 11.5783 7.69084 11.394 7.79602Z" fill="white"/>
                                </svg>
                                <span class="uppercase">Listen to my Latest Work</span>
                            </a>
                            <a href="#contact" class="inline-flex items-center gap-2 hover:brightness-90 px-4 py-2.5 border border-[#EC003F] rounded-4xl text-[#EC003F] hover:scale-102 transition-all duration-300 hover:cursor-pointer">
                                <span class="font-normal uppercase">Book a Session</span>
                                <ArrowRight class="w-4 h-4" />
                            </a>
                        </div>
                    </div>
                </div>
            </section>

			<script>
				declare global {
					interface Window {
						THREE: any; // @todo refactor
					}
				}

				document.addEventListener('DOMContentLoaded', () => {
					const threeContainer = document.getElementById('three-container')!;
					const heroLogo = document.getElementById('hero-logo')!;
					const waveBars = document.querySelectorAll('.wave-bar')! as NodeListOf<HTMLElement>;
					
					const delayedHeader = document.getElementById('delayed-header')!;
					const delayedBadge = document.getElementById('delayed-badge')!;
					const delayedText = document.getElementById('delayed-text')!;
					const delayedButtons = document.getElementById('delayed-buttons')!;
					const delayedUI = [delayedHeader, delayedBadge, delayedText, delayedButtons];

                    // --- If not home, fade the top bar in immediately ---
                    const isHome = window.location.pathname === '/' && (!window.location.hash || window.location.hash === '#home');

                    if (!isHome) {
                        if (delayedHeader) {
                            delayedHeader.classList.replace('opacity-0', 'opacity-100');
                            delayedHeader.classList.remove('pointer-events-none');
                        }
                    }

					// --- PHASE TIMERS ---

					// 1. FLASH (500ms)
					setTimeout(() => {
						// Lights
						threeContainer.classList.replace('opacity-0', 'opacity-100');
						threeContainer.classList.replace('scale-95', 'scale-100');
						threeContainer.classList.replace('duration-0', 'duration-[1500ms]');
						threeContainer.classList.add('brightness-[1.5]', 'ease-out');
						
						// Logo SVG (Flash to bright)
						heroLogo.classList.replace('brightness-5', 'brightness-[1.5]');
						heroLogo.classList.replace('scale-[0.98]', 'scale-[1.01]');
						heroLogo.classList.add('duration-[1500ms]', 'ease-out');
					}, 500);

					// 2. STEADY (1000ms)
					setTimeout(() => {
						// Settle Lights
						threeContainer.classList.replace('brightness-[1.5]', 'brightness-100');
						threeContainer.classList.replace('duration-[1500ms]', 'duration-[1000ms]');
						threeContainer.classList.replace('ease-out', 'ease-in-out');

						// Settle Logo
						heroLogo.classList.replace('brightness-[1.5]', 'brightness-100');
						heroLogo.classList.replace('scale-[1.01]', 'scale-100');
					}, 1000);

					// 3. WAVE_IN (2000ms)
					setTimeout(() => {
						waveBars.forEach(bar => {
							bar.classList.replace('opacity-0', 'opacity-100');
						});
					}, 2000);

					// 4. PLAY (3250ms)
					setTimeout(() => {
						// Start Waveform
						waveBars.forEach(bar => {
							bar.style.transform = ''; // Clear initial transform to let keyframes take over
							bar.style.transitionDelay = '0s'; // Reset stagger
							bar.classList.add('animate-eq');
						});

						// Reveal UI (Header, Badge, Bottom Text, Buttons)
						delayedUI.forEach(el => {
							if(el) {
								el.classList.replace('opacity-0', 'opacity-100');
								el.classList.remove('pointer-events-none');
							}
						});
					}, 3250);

					// --- THREE.JS INITIALIZATION ---
					const initThree = () => {
						if (!window.THREE || !threeContainer) return;
						
						const THREE = window.THREE;
						let w = window.innerWidth;
						let h = window.innerHeight;

						const scene = new THREE.Scene();
						const camera = new THREE.OrthographicCamera(-w/2, w/2, h/2, -h/2, 0.1, 100);
						camera.position.z = 10;

						const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
						renderer.setSize(w, h);
						renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2)); 
						threeContainer.appendChild(renderer.domElement);

						const baseGeo = new THREE.PlaneGeometry(1, 1);
						baseGeo.translate(0.5, 0, 0); 

						const createBeamMat = (intensity: number) => new THREE.ShaderMaterial({
							uniforms: {
								uColor: { value: new THREE.Color(0xffffff) },
								uIntensity: { value: intensity }
							},
							vertexShader: `
								varying vec2 vUv;
								void main() {
									vUv = uv;
									gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
								}
							`,
							fragmentShader: `
								varying vec2 vUv;
								uniform vec3 uColor;
								uniform float uIntensity;
								void main() {
									vec2 origin = vec2(0.0, 0.5); 
									float dist = length((vUv - origin) * vec2(1.0, 2.5)); 
									
									float originFade = smoothstep(0.0, 0.05, vUv.x);
									float alpha = pow(smoothstep(1.0, 0.0, dist), 1.5) * uIntensity * originFade;
									
									gl_FragColor = vec4(uColor * alpha, alpha);
								}
							`,
							transparent: true,
							blending: THREE.AdditiveBlending,
							depthWrite: false,
						});

						const glow = new THREE.Mesh(baseGeo, createBeamMat(0.50));  
						const beam1 = new THREE.Mesh(baseGeo, createBeamMat(0.40)); 
						const beam2 = new THREE.Mesh(baseGeo, createBeamMat(0.65)); 
						const beam3 = new THREE.Mesh(baseGeo, createBeamMat(0.40)); 

						scene.add(glow);
						scene.add(beam1);
						scene.add(beam2);
						scene.add(beam3);

						const updateLayout = () => {
							w = window.innerWidth;
							h = window.innerHeight;

							camera.left = -w/2;
							camera.right = w/2;
							camera.top = h/2;
							camera.bottom = -h/2;
							camera.updateProjectionMatrix();
							renderer.setSize(w, h);
							
							renderer.domElement.style.position = 'absolute';
							renderer.domElement.style.top = '0';
							renderer.domElement.style.left = '0';

							const overscan = 50; 
							const cornerDist = Math.hypot(w / 2, h / 2);
							const dirX = (w / 2) / cornerDist;
							const dirY = (h / 2) / cornerDist;

							const beamStart = {
								x: (w / 2) + (dirX * overscan),
								y: (h / 2) + (dirY * overscan),
								d: Math.min(w, h) * 0.08 
							};

							const destOffset = 30; 
							const beamEnd = {
								x: 0 - destOffset,
								y: 0 - destOffset,
								d: Math.min(w, h) * 0.26
							};

							const bleedFactor = 1.3;

							// Glow
							const g_dist = Math.hypot(beamEnd.x - beamStart.x, beamEnd.y - beamStart.y);
							glow.position.set(beamStart.x, beamStart.y, 0);
							glow.rotation.z = Math.atan2(beamEnd.y - beamStart.y, beamEnd.x - beamStart.x);
							glow.scale.set(g_dist * bleedFactor, g_dist * 0.55, 1); 

							// Beam 2
							const b2_ox = beamStart.x;
							const b2_oy = beamStart.y;
							const b2_tx = beamEnd.x;
							const b2_ty = beamEnd.y;
							const dist2 = Math.hypot(b2_tx - b2_ox, b2_ty - b2_oy);
							
							beam2.position.set(b2_ox, b2_oy, 0);
							beam2.rotation.z = Math.atan2(b2_ty - b2_oy, b2_tx - b2_ox);
							beam2.scale.set(dist2 * bleedFactor, dist2 * 0.22, 1); 

							// Beam 1
							const b1_ox = beamStart.x - beamStart.d;
							const b1_oy = beamStart.y;
							const b1_tx = beamEnd.x;
							const b1_ty = beamEnd.y + beamEnd.d; 
							const dist1 = Math.hypot(b1_tx - b1_ox, b1_ty - b1_oy);
							
							beam1.position.set(b1_ox, b1_oy, 0);
							beam1.rotation.z = Math.atan2(b1_ty - b1_oy, b1_tx - b1_ox);
							beam1.scale.set(dist1 * bleedFactor, dist1 * 0.30, 1); 

							// Beam 3
							const b3_ox = beamStart.x;
							const b3_oy = beamStart.y - beamStart.d; 
							const b3_tx = beamEnd.x + beamEnd.d;
							const b3_ty = beamEnd.y;
							const dist3 = Math.hypot(b3_tx - b3_ox, b3_ty - b3_oy);
							
							beam3.position.set(b3_ox, b3_oy, 0);
							beam3.rotation.z = Math.atan2(b3_ty - b3_oy, b3_tx - b3_ox);
							beam3.scale.set(dist3 * bleedFactor, dist3 * 0.30, 1); 
						};

						window.addEventListener('resize', updateLayout);
						updateLayout();

						const animate = () => {
							requestAnimationFrame(animate);
							renderer.render(scene, camera);
						};
						animate();
					};

					// Load Three.js dynamically
					if (window.THREE) {
						initThree();
					} else {
						const script = document.createElement('script');
						script.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
						script.onload = initThree;
						document.head.appendChild(script);
					}
				});
			</script>

			<!-- ABOUT SECTION -->
			<section id="about" class="bg-zinc-950 px-6 xl:px-0 w-full min-h-screen">
    			<div class="flex flex-col opacity-0 w-full transition-opacity duration-800 ease-out reveal">
					<div class="flex md:flex-row flex-col md:justify-between items-center gap-10 md:gap-0 mx-auto py-16 md:py-12 w-full max-w-7xl">
						<div class="inline-flex items-center gap-4">
							<span>KEEP EXPLORING</span>
							<svg width="32" height="18" viewBox="0 0 32 18" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5">
								<line class="eq-line" style="--delay: 0.0s; --dur: 0.8s;" x1="1" y1="6" x2="1" y2="12" stroke="#EC003F" stroke-opacity="0.88" stroke-width="2" stroke-linecap="round"/>
								<line class="eq-line" style="--delay: -0.3s; --dur: 1.1s;" x1="7" y1="2" x2="7" y2="16" stroke="#EC003F" stroke-opacity="0.88" stroke-width="2" stroke-linecap="round"/>
								<line class="eq-line" style="--delay: -0.6s; --dur: 0.9s;" x1="13" y1="4" x2="13" y2="14" stroke="#EC003F" stroke-opacity="0.88" stroke-width="2" stroke-linecap="round"/>
								<line class="eq-line" style="--delay: -0.2s; --dur: 1.2s;" x1="19" y1="3" x2="19" y2="15" stroke="#EC003F" stroke-opacity="0.88" stroke-width="2" stroke-linecap="round"/>
								<line class="eq-line" style="--delay: -0.8s; --dur: 1.0s;" x1="25" y1="1" x2="25" y2="17" stroke="#EC003F" stroke-opacity="0.88" stroke-width="2" stroke-linecap="round"/>
								<line class="eq-line" style="--delay: -0.4s; --dur: 0.85s;" x1="31" y1="6" x2="31" y2="12" stroke="#EC003F" stroke-opacity="0.88" stroke-width="2" stroke-linecap="round"/>
							</svg>
						</div>
						<div class="flex flex-col items-center md:items-end">
							<span class="text-zinc-500">RECORDED LIVE FROM</span>
							<span>25°25'S · 49°16'W — CURITIBA</span>
						</div>
					</div>

					<hr class="border-white/5 border-t">

					<div class="inline-flex items-center gap-4 mx-auto py-12 lg:py-16 w-full max-w-7xl">
						<span class="text-red-500 text-5xl">“</span>
						<span class="text-zinc-500">FIRST-PERSON NOTES</span>
					</div>

					<div class="relative gap-12 lg:gap-8 grid lg:grid-cols-3 mx-auto pb-12 max-w-7xl">
						<div class="z-10 flex flex-col lg:justify-between gap-12 lg:gap-0 order-2 lg:order-1 col-span-3 lg:col-span-2">
							<p class="font-medium md:text-[2.75rem] text-4xl tracking-wide">
								I don't chase trends. I chase <span class="text-red-500 italic">the song</span> that a listener won't skip — the one that makes them sit still for three minutes.
							</p>

							<span>
								<div class="bg-red-500 rounded w-12 h-0.5"></div>
								<p class="mt-6 lg:max-w-xl font-light text-zinc-400 text-xl">
									I started out stacking raw guitar tracks into a cracked DAW. Over a decade later, the studio is bigger and the mixes hit harder, but the question hasn't changed: does this track earn its length?
								</p>
							</span>

							<div class="flex flex-wrap justify-center lg:justify-start items-center self-center lg:self-start gap-3 lg:max-w-lg max-w-xl">
								<a href={SOCIAL_INSTAGRAM} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
									Instagram
								</a>
								<a href={SOCIAL_YOUTUBE} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
									YouTube
								</a>
								<a href={SOCIAL_TIKTOK} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
									TikTok
								</a>
								<a href={SOCIAL_SPOTIFY} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
									Spotify
								</a>
								<a href={SOCIAL_DEEZER} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
									Deezer
								</a>
								<a href={SOCIAL_YOUTUBE_MUSIC} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
									Youtube Music
								</a>
								<a href={SOCIAL_APPLE_MUSIC} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
									Apple Music
								</a>
								<a href={SOCIAL_AMAZON_MUSIC} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
									Amazon Music
								</a>
								<a href={SOCIAL_AIRBIT} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
									Airbit
								</a>
								<a href={SOCIAL_FIVERR} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
									Fiverr
								</a>
							</div>
						</div>

						<div class="z-10 flex flex-col lg:justify-between gap-8 lg:gap-0 order-1 lg:order-2 col-span-3 lg:col-span-1 bg-[#121212]/40 p-8 border border-[#202020]/20 rounded-xl h-auto lg:h-134">
							<img src={tallesPic.src} alt="Talles Cattarin" class="col-span-1 shadow-md border border-[#202020]/80 rounded-md h-auto lg:h-83 object-cover" />

							<div class="flex flex-col gap-2">
								<span class="font-light text-red-500 text-base tracking-wide">THE ARTIST</span>
								<span class="mt-1.5 text-3xl tracking-wider">Talles Cattarin</span>
								<span class="text-zinc-500 text-sm">Music producer, singer and audio engineer</span>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- SERVICES SECTION -->
			<section id="services" class="flex flex-col bg-zinc-950 pt-22">
    			<div class="flex flex-col opacity-0 w-full transition-opacity duration-700 ease-out reveal">
					<div class="space-y-2 md:space-y-4 mb-20 px-6 xl:px-0 text-center">
						<h2 class="font-medium text-5xl md:text-6xl tracking-normal">
							Three services.
						</h2>
						<p class="font-medium text-3xl md:text-6xl tracking-normal">
							Each done properly.
						</p>
						<p class="mt-10 text-zinc-500 uppercase text-balance">Nothing rushed. Typical turnaround: 5–7 days.</p>
					</div>

					<div class="bg-[#0B0B0B] py-10 border-white/4 border-x-8 border-y">
						<div class="place-items-center grid lg:grid-cols-2 mx-auto px-6 xl:px-0 py-4 rounded-2xl w-full max-w-7xl">
							<div class="flex flex-col gap-8 lg:order-1 col-span-1 lg:py-6 pb-8 rounded-3xl w-full">
								<h3 class="flex flex-col gap-2">
									<span class="font-light text-red-500 uppercase tracking-wider">Music</span>
									<span class="font-semibold text-2xl">Production</span>
								</h3>
								
								<p class="lg:max-w-sm font-light text-zinc-300 lg:text-lg text-xl leading-relaxed">
									I create and shape your music from concept to final product, ensuring every element is polished and impactful.
								</p>

								<a href="#contact" class="inline-flex items-center gap-2 text-zinc-500 hover:text-white text-sm uppercase transition-colors duration-150">
									Learn More
									<ArrowRight class="w-4 h-4" />
