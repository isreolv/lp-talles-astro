---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Talles Cattarin</h1>
			<p class="text-red-500">Draft website to test new workflow</p>
			<p>
				Musician, Singer and Audio Engineer.
			</p>
			<p>Crafting sonic experiences that move hearts and shake souls</p>
			<p>
				I'm Talles Cattarin, a music producer dedicated to creating powerful, high-quality sound through modern mixing and mastering.
			</p>
			<h2>Services</h2>
			<p>
				I’ll shape your music into an immersive, polished, and emotionally powerful experience.
			</p>
			<h3>Professional Mixing</h3>
			<p>
				I transform your raw tracks into a cohesive and impactful sound, ensuring every instrument and vocal shines in the right place.
			</p>
			<h3>High-Quality Mastering</h3>
			<p>
				Mastering gives your music its final polish, enhancing clarity, balance, and loudness so it sounds professional on any platform.
			</p>
			<h2>Projects</h2>
			<p>Discover how quality mixing and mastering can make a difference.</p>
			<iframe
				data-testid="embed-spotify-iframe"
				style="border-radius:12px;border:none;"
				src="https://open.spotify.com/embed/artist/77SAbQybNSZmuluK93v8AO?utm_source=generator&theme=0"
				width="100%"
				height="352"
				allowfullscreen=""
				allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
				loading="lazy"
			>
			</iframe>
			<button>Ready to Transform Your Music?</button>
			<h2>Reach</h2>
			<p>My music has reached listeners all around the world.</p>
			<dl>
				<dt>Views</dt>
				<dd>350K+</dd>
				<dt>Likes</dt>
				<dd>35K+</dd>
				<dt>Interactions</dt>
				<dd>20K+</dd>
				<dt>Spotify Monthly Listeners</dt>
				<dd>2.5K+</dd>
			</dl>
			<h2>Contact</h2>
			<p>To request a quote or ask questions, reach out directly via Instagram, Whatsapp or e-mail. Let’s work together to make your ideas sound their best!</p>
			<span>
				<button>Connect on Instagram</button>
				<button>Send a Whatsapp Message</button>
				<button>Send an E-mail</button>
			</span>
			<h2>
				Support My Work
			</h2>
			<p>If you enjoy my work and would like to support my musical journey, consider making a donation. Your contribution helps me continue producing quality content and investing in new creative projects.</p>
			<span>
				<button>Patreon</button>
				<button>PayPal</button>
			</span>
		</main>
		<Footer />
	</body>
</html>
