---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, CONTACT_WHATSAPP } from '../consts';

import SendIcon from '@lucide/astro/icons/send';
import AudioLinesIcon from '@lucide/astro/icons/audio-lines';
import InstagramIcon from '@lucide/astro/icons/instagram';
import MailIcon from '@lucide/astro/icons/mail';
import HeartIcon from '@lucide/astro/icons/heart';
import tallesHeroSvg from '../assets/talles-hero.svg';

import tallesPic from '../assets/talles.webp';
import placeholder1 from '../assets/blog-placeholder-2.jpg';
import placeholder2 from '../assets/blog-placeholder-3.jpg';
import placeholder3 from '../assets/blog-placeholder-4.jpg';
import placeholder4 from '../assets/blog-placeholder-5.jpg';
import Waveform from '../components/icons/Waveform.astro';
import { ArrowRight } from '@lucide/astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="selection:bg-red-600 selection:text-white antialiased">
		<!-- Background Effects -->
		<!-- <div class="-z-10 fixed inset-0 overflow-hidden pointer-events-none">
			<div class="top-[-10%] left-[-10%] absolute bg-red-900/10 blur-[120px] rounded-full w-[50%] h-[50%]"></div>
			<div class="right-[-10%] bottom-[-10%] absolute bg-red-600/5 blur-[150px] rounded-full w-[40%] h-[40%]"></div>
		</div> -->

		<Header />


		<!-- <h1 class="font-black text-6xl md:text-8xl leading-none tracking-tighter">
			Talles Cattarin
		</h1> -->

		<main>
			<!-- HERO SECTION -->
			<section id="home" class="hero-bg">
				<div class="z-20 absolute inset-0 overflow-hidden pointer-events-none">
					<div class="relative w-full h-full">
						<div class="stage-light ellipse-glow"></div>
						<div class="stage-light ellipse-1"></div>
						<div class="stage-light ellipse-2"></div>
						<div class="stage-light ellipse-3"></div>
					</div>
				</div>

				<div class="relative flex flex-col mx-auto py-16 max-w-7xl h-screen">
					<div class="flex flex-col justify-center items-center gap-8 h-full">
						<p class="top-56 z-0 absolute font-gothic md:text-[9rem] text-xl tracking-widest hero-title">
							Talles Cattarin
						</p>

						<div class="inline-flex z-10 justify-center items-center space-x-4 bg-zinc-950 p-3 border border-[#1C1C1C] rounded-[40px] text-white/80">
							<AudioLinesIcon class="w-5 h-5 text-red-500" />
							<p>Music Producer, Singer and Audio Engineer</p>
						</div>

						<img src={tallesHeroSvg.src} class="z-10 mt-4 w-full max-w-2xl hover:rotate-1 transition-transform duration-300" alt="Talles Cattarin" />

						<Waveform />
					</div>

					<div class="z-10 flex justify-between items-end w-full">
						<p class="z-10 max-w-2xl font-light text-gray-400 text-xs md:text-sm uppercase leading-relaxed tracking-wide">
							Crafting sonic  · Building cultural
						</p>
						<div class="flex flex-col items-end gap-4">
							<a href="#studio" class="inline-flex items-center gap-2 bg-[#EC003F] px-4 py-2.5 rounded-4xl transition-all hover:cursor-pointer">
								<svg width="12" height="14" viewBox="0 0 12 14" fill="none" xmlns="http://www.w3.org/2000/svg">
									<path d="M11.394 7.79602L1.8495 13.334C1.0395 13.8035 0 13.235 0 12.2885V1.21252C0 0.267522 1.038 -0.302478 1.8495 0.168522L11.394 5.70652C11.5783 5.81171 11.7314 5.96375 11.8379 6.14723C11.9445 6.33071 12.0006 6.53911 12.0006 6.75127C12.0006 6.96344 11.9445 7.17183 11.8379 7.35531C11.7314 7.53879 11.5783 7.69084 11.394 7.79602Z" fill="white"/>
								</svg>
								<span class="uppercase">Listen to my Latest Work</span>
							</a>
							<a href="#contact" class="inline-flex items-center gap-2 px-4 py-2.5 border border-[#EC003F] rounded-4xl text-[#EC003F] hover:cursor-pointer">
								<span class="uppercase">Book a Session</span>
								<ArrowRight	class="w-4 h-4" />
							</a>
						</div>
					</div>
				</div>
			</section>

			<!-- ABOUT SECTION -->
			<section id="about" class="flex flex-col bg-zinc-950 w-full h-screen">
				<div class="inline-flex justify-between items-center mx-auto py-12 w-full max-w-7xl">
					<div class="inline-flex items-center gap-4">
						<span>KEEP EXPLORING</span>
						<AudioLinesIcon class="w-5 h-5 text-red-500" />
					</div>
					<div class="flex flex-col items-end">
						<span class="text-zinc-500">RECORDED LIVE FROM</span>
						<span>25°25'S · 49°16'W — CURITIBA</span>
					</div>
				</div>

				<hr class="border-white/5 border-t">

				<div class="inline-flex items-center gap-4 mx-auto py-12 w-full max-w-7xl">
					<span class="text-red-500 text-5xl">“</span>
					<span class="text-zinc-500">FIRST-PERSON NOTES</span>
				</div>

				<div class="relative gap-8 grid md:grid-cols-3 mx-auto pb-12 max-w-7xl">
					<div class="z-10 flex flex-col col-span-2">
						<span class="font-medium text-[2.75rem] tracking-wide">
							I don't chase trends. I chase <span class="text-red-500 italic">the song</span> that a listener won't skip — the one that makes them sit still for three minutes.
						</span>

						<div class="bg-red-500 mt-16 rounded w-12 h-0.5"></div>
						
						<p class="mt-6 max-w-xl font-light text-zinc-400 text-xl">
							I was fourteen when I bootlegged my first mix on a cracked DAW. Twelve years later, the room is bigger, the monitors are better, the question hasn't changed: does this song earn its length?
						</p>
					</div>

					<div class="z-10 flex flex-col justify-between bg-[#121212] p-6 border border-[#202020] rounded-xl h-134">
						<img src={tallesPic.src} alt="Talles Cattarin" class="col-span-1 shadow-md border border-[#202020] rounded-xl h-83 object-cover" />
						<div class="flex flex-col gap-2">
							<span class="text-3xl tracking-wide">Talles Cattarin</span>
							<span class="text-zinc-500 text-sm">Music producer, singer and audio engineer</span>
						</div>
					</div>
				</div>
			</section>

			<!-- SERVICES SECTION -->
			<section id="services" class="bg-zinc-950 pt-8">
				<div class="flex flex-col">
					<div class="space-y-4 mb-20 text-center">
						<h2 class="font-medium text-6xl tracking-normal">
							Three services.
						</h2>
						<p class="font-medium text-6xl tracking-normal">
							Each done properly.
						</p>
						<p class="mt-10 text-zinc-500 uppercase">Nothing rushed. Typical turnaround: 5–7 days.</p>
					</div>

					<div class="bg-[#0B0B0B] py-10 border-white/5 border-x-8 border-y">
						<div class="grid md:grid-cols-2 mx-auto rounded-2xl w-full max-w-7xl">
							<div class="flex flex-col gap-8 md:order-1 col-span-1 py-6 rounded-3xl">
								<h3 class="flex flex-col gap-2">
									<span class="font-light text-red-500 uppercase tracking-wider">Music</span>
									<span class="font-semibold text-2xl">Production</span>
								</h3>
								
								<p class="max-w-sm font-light text-zinc-300 text-lg leading-relaxed">
									I create and shape your music from concept to final product, ensuring every element is polished and impactful.
								</p>

								<a href="#contact" class="inline-flex items-center gap-2 text-zinc-500 text-sm uppercase">
									Learn More
									<ArrowRight class="w-4 h-4" />
								</a>
							</div>
							<img class="md:order-2 col-span-1 bg-zinc-900 rounded-lg h-92" src={placeholder1.src} alt="Placeholder" />
						</div>
					</div>

					<div class="bg-[#0B0B0B] py-10 border-white/5 border-x-8 border-y">
						<div class="grid md:grid-cols-2 mx-auto rounded-2xl w-full max-w-7xl">
							<div class="flex flex-col gap-8 md:order-2 col-span-1 py-6 md:pl-8 rounded-3xl">
								<h3 class="flex flex-col gap-2">
									<span class="font-light text-red-500 uppercase tracking-wider">Professional</span>
									<span class="font-semibold text-2xl">Mixing and Mastering</span>
								</h3>
								
								<p class="max-w-lg font-light text-zinc-300 text-lg leading-relaxed">
									I transform your raw tracks into a cohesive and impactful sound, balancing every element so 
									each instrument and vocal sits perfectly in the mix—resulting in a polished,
									professional sound that translates well across any platform.
								</p>

								<a href="#contact" class="inline-flex items-center gap-2 text-zinc-500 text-sm uppercase">
									Learn More
									<ArrowRight class="w-4 h-4" />
								</a>
							</div>
							<img class="md:order-1 col-span-1 bg-zinc-900 rounded-lg h-92" src={placeholder2.src} alt="Placeholder" />
						</div>
					</div>

					<div class="bg-[#0B0B0B] py-10 border-white/5 border-x-8 border-y">
						<div class="grid md:grid-cols-2 mx-auto rounded-2xl w-full max-w-7xl">
							<div class="flex flex-col md:order-1 col-span-1 py-6 rounded-3xl">
								<h3 class="flex flex-col gap-2">
									<span class="font-light text-red-500 uppercase tracking-wider">Singer</span>
									<span class="font-semibold text-2xl">Solo or duet</span>
								</h3>
								
								<p class="mt-8 max-w-lg font-light text-zinc-300 text-lg leading-relaxed">
									I bring your lyrics to life, delivering emotive and dynamic vocal performances that connect with your audience.
								</p>

								<p class="mt-2 max-w-lg font-light text-zinc-300 text-lg leading-relaxed">
									I also team up with Denisse Ferrara, a talented vocalist, to offer a wider range of vocal styles and collaborations for your music projects.
								</p>

								<a href="#contact" class="inline-flex items-center gap-2 mt-8 text-zinc-500 text-sm uppercase">
									Learn More
									<ArrowRight class="w-4 h-4" />
								</a>
							</div>
							<img class="md:order-2 col-span-1 bg-zinc-900 rounded-lg h-92" src={placeholder4.src} alt="Placeholder" />
						</div>
					</div>
				</div>
			</section>

			<!-- REACH / STATS SECTION -->
			<section id="studio" class="flex flex-col gap-16 mx-auto px-6 pt-28 pb-20 max-w-7xl">
				<div class="grid md:grid-cols-3">
					<div class="flex flex-col gap-6 col-span-1">
						<span class="text-9xl">10+</span>
						<span class="text-zinc-500 uppercase tracking-wider">YEARS OF EXPERIENCE</span>
					</div>
					<div class="flex flex-col justify-end gap-8 col-span-2">
						<p class="font-light text-white text-3xl md:text-right uppercase tracking-wider">
							Crafting sonic landscapes. <br>Building cultural moments.
						</p>
						<p class="font-light text-white/60 text-xl md:text-right uppercase tracking-wider">
							Crafting sonic landscapes. <br>Building cultural moments.
						</p>
					</div>
				</div>

				<hr class="border-white/5 border-t">

				<div class="grid md:grid-cols-3">
					<div class="flex flex-col gap-6 col-span-1">
						<!--
						RATIONAL
						Fiverr: 45
						Spotify: 73 rock 47 acoustic 19 others
						Total: 184
						-->
						<span class="text-8xl">184</span>
						<span class="text-zinc-500 uppercase tracking-wider">PROJECTS COMPLETED</span>
					</div>
					<div class="flex flex-col gap-6 col-span-1">
						<span class="text-8xl">500K+</span>
						<span class="text-zinc-500 uppercase tracking-wider">STREAMS</span>
					</div>
					<div class="flex flex-col gap-6 col-span-1">
						<!--
						RATIONAL
						Estimating a bit more than 10% of total streams as interactions (likes, comments, shares, saves)
						-->
						<span class="text-8xl">60K+</span>
						<span class="text-zinc-500 uppercase tracking-wider">INTERACTIONS</span>
					</div>
				</div>
			</section>

			<!-- PORTFOLIO SECTION -->
			<section class="flex flex-col gap-16 mx-auto py-24 max-w-7xl min-h-screen">
				<h2 class="font-light text-5xl uppercase tracking-tight">
					Productions
				</h2>

				<div class="gap-4 grid grid-cols-2 h-full">
					<img src={placeholder1.src} alt="Placeholder" class="col-span-1 rounded-lg h-full object-cover" />
					<div class="gap-4 grid grid-cols-2 col-span-1">
						<img src={placeholder2.src} alt="Placeholder" class="col-span-1 rounded-lg h-full object-cover" />
						<img src={placeholder3.src} alt="Placeholder" class="col-span-1 rounded-lg h-full object-cover" />
						<img src={placeholder4.src} alt="Placeholder" class="col-span-2 rounded-lg h-full object-cover" />
					</div>
				</div>
			</section>

			<section id="contact" class="relative flex flex-col justify-center items-center w-full h-192 overflow-hidden text-center">
				<span class="cta-glow"></span>

				<div class="inline-flex z-10 justify-center items-center gap-2 bg-zinc-950 p-3 px-4 border border-[#1C1C1C] rounded-[40px] text-white/80">
					<div class="bg-red-500 rounded-full size-2 animate-pulse"></div>
					<p class="text-sm">NEXT TRACK</p>
				</div>

				<span class="z-10 mt-20 mb-8 font-bold text-xl md:text-7xl">
					Bring the song.
				</span>
				<span class="z-10 font-bold text-zinc-500 text-xl md:text-7xl">
					I'll bring the sound.
				</span>

				<div class="inline-flex z-10 items-center gap-8 mt-20">
					<a href={CONTACT_WHATSAPP} class="inline-flex items-center gap-2 bg-[#EC003F] px-4 py-3 rounded-4xl transition-all hover:cursor-pointer">
						<span class="tracking-wide">START A PROJECT</span>
						<ArrowRight	class="w-4 h-4" />
					</a>
					<a href="mailto:studio@tallescattarin.com" class="font-medium text-zinc-500 text-sm decoration-zinc-500 underline uppercase tracking-wide hover:cursor-pointer">studio@tallescattarin.com</a>
				</div>
			</section>

			<!-- SUPPORT SECTION -->
			<!-- <section class="mx-auto px-6 py-24 max-w-3xl text-center"> -->
				<!-- Heart Icon -->
				 <!-- 
				<div class="flex justify-center mb-6 text-rose-500">
					<HeartIcon class="size-16" />
				</div>

				<h2 class="mb-4 font-bold text-4xl">Support My Work</h2>
				<p class="mb-8 text-gray-500 leading-relaxed">
					If you enjoy my work and would like to support my musical journey, consider making a donation.
          			Your contribution helps me continue producing quality content and investing in new creative projects.
				</p>
				<div class="flex justify-center gap-6">
					<a href={DONATION_PATREON} class="flex items-center gap-2 font-bold text-gray-400 hover:text-white text-sm transition-colors">
						<svg class="size-6" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<title>Patreon</title>
							<path fill="white" d="M22.957 7.21c-.004-3.064-2.391-5.576-5.191-6.482-3.478-1.125-8.064-.962-11.384.604C2.357 3.231 1.093 7.391 1.046 11.54c-.039 3.411.302 12.396 5.369 12.46 3.765.047 4.326-4.804 6.068-7.141 1.24-1.662 2.836-2.132 4.801-2.618 3.376-.836 5.678-3.501 5.673-7.031Z"/>
						</svg>
						PATREON
					</a>
					<span class="text-zinc-800">|</span>
					<a href={DONATION_PAYPAL} class="flex items-center gap-2 font-bold text-gray-400 hover:text-white text-sm transition-colors">
						<svg class="size-6" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<title>PayPal</title>
							<path fill="white" d="M15.607 4.653H8.941L6.645 19.251H1.82L4.862 0h7.995c3.754 0 6.375 2.294 6.473 5.513-.648-.478-2.105-.86-3.722-.86m6.57 5.546c0 3.41-3.01 6.853-6.958 6.853h-2.493L11.595 24H6.74l1.845-11.538h3.592c4.208 0 7.346-3.634 7.153-6.949a5.24 5.24 0 0 1 2.848 4.686M9.653 5.546h6.408c.907 0 1.942.222 2.363.541-.195 2.741-2.655 5.483-6.441 5.483H8.714Z"/>
						</svg>
						PAYPAL
					</a>
				</div>
			</section> -->
		</main>

		<Footer />
	</body>
</html>
