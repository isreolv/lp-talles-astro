---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, DONATION_PATREON, DONATION_PAYPAL } from '../consts';

import SendIcon from '@lucide/astro/icons/send';
import AudioLinesIcon from '@lucide/astro/icons/audio-lines';
import InstagramIcon from '@lucide/astro/icons/instagram';
import MailIcon from '@lucide/astro/icons/mail';
import HeartIcon from '@lucide/astro/icons/heart';
import tallesHeroSvg from '../assets/talles-hero.svg';

import placeholder1 from '../assets/blog-placeholder-2.jpg';
import placeholder2 from '../assets/blog-placeholder-3.jpg';
import placeholder3 from '../assets/blog-placeholder-4.jpg';
import placeholder4 from '../assets/blog-placeholder-5.jpg';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="antialiased selection:bg-red-600 selection:text-white">
		<!-- Background Effects -->
		<!-- <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
			<div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-red-900/10 rounded-full blur-[120px]"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-red-600/5 rounded-full blur-[150px]"></div>
		</div> -->

		<Header />


		<!-- <h1 class="text-6xl md:text-8xl font-black tracking-tighter leading-none">
			Talles Cattarin
		</h1> -->

		<main>
			<!-- HERO SECTION -->
			<section id="home" class="flex flex-col justify-center items-center h-screen px-6 max-w-7xl mx-auto gap-6">
				<p class="absolute top-32 text-red-500 font-mono tracking-widest text-sm uppercase animate-pulse">
					WIP
				</p>

				<div class="inline-flex space-x-4 items-center justify-center text-white/80 border border-[#1C1C1C] px-3 py-2 rounded-[40px] bg-zinc-950">
					<div class="p-2 rounded-full border border-[#1C1C1C]">
						<AudioLinesIcon class="w-6 h-6" />
					</div>
					<p>Music Producer, Singer and Audio Engineer</p>
				</div>

				<img src={tallesHeroSvg.src} alt="Talles Cattarin" class="w-full max-w-2xl mt-4 transition-transform duration-300 hover:rotate-1" />
				
				<p class="text-sm md:text-base text-gray-400 font-semibold max-w-2xl leading-relaxed tracking-wide uppercase">
					Crafting sonic  · Building cultural
				</p>
				<!-- <p class="text-gray-500 max-w-xl">
					I'm Talles Cattarin, a music producer dedicated to creating powerful, high-quality sound through modern mixing and mastering.
				</p> -->
				<!-- <div class="flex flex-wrap gap-4 pt-4">
					<a href="#contact" class="px-8 py-4 bg-rose-600 hover:bg-rose-700 text-white font-bold rounded-xl transition-all flex items-center gap-2 group">
						Start Your Project
						<ArrowRightIcon class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
					</a>
				</div> -->
			</section>

			<!-- ABOUT SECTION -->
			<section id="about" class="py-24 px-6 h-screen bg-zinc-950">
				<div class="grid md:grid-cols-3 max-w-7xl mx-auto gap-8">
					<img src={placeholder1.src} alt="Placeholder" class="col-span-1 h-134 rounded-lg" />
					<div class="col-span-2 flex flex-col gap-12">
						<h2 class="text-5xl font-light tracking-wide uppercase">
							Hi, I'm Talles!
						</h2>

						<p class="text-4xl font-light tracking-wide uppercase">
							Musician, singer and audio engineer from Curitiba, Brazil.
						</p>
						
						<p class="text-2xl font-light uppercase text-white/60">
							I create reinterpretations of songs that marked generations and my life as well.
						</p>
					</div>
				</div>
			</section>

			<!-- SERVICES SECTION -->
			<section id="services" class="py-24 px-6 bg-zinc-950">
				<div class="flex flex-col max-w-7xl mx-auto gap-8">
					<div class="text-center space-y-4 mb-4">
						<h2 class="text-2xl font-black tracking-tight">
							SERVICES
							<AudioLinesIcon class="w-4 h-4 inline-block text-red-600 ml-2" />
						</h2>
					</div>

					<div class="sticky top-20 z-10 h-120 w-full grid md:grid-cols-2 rounded-2xl p-6 bg-black">
						<div class="col-span-1 flex flex-col gap-8 rounded-3xl px-8 py-6">
							<h3 class="text-2xl font-semibold uppercase">Music <br />Production</h3>
							
							<svg width="16" height="8" viewBox="0 0 16 8" fill="none" xmlns="http://www.w3.org/2000/svg">
								<line x1="7" y1="1" x2="1" y2="1" stroke="#EC003F" stroke-opacity="0.88" stroke-width="2" stroke-linecap="round"/>
								<line x1="15" y1="7" x2="1" y2="7" stroke="#EC003F" stroke-opacity="0.88" stroke-width="2" stroke-linecap="round"/>
							</svg>
							
							<p class="text-gray-400 text-xl leading-relaxed font-light">
								I create and shape your music from concept to final product, ensuring every element is polished and impactful.
							</p>
						</div>
						<img class="col-span-1 h-108 rounded-lg bg-zinc-900" src={placeholder1.src} alt="Placeholder" />
					</div>

					<div class="sticky top-24 z-20 h-120 w-full grid md:grid-cols-2 rounded-2xl p-6 bg-black">
						<div class="col-span-1 flex flex-col gap-8 rounded-3xl px-8 py-6">
							<h3 class="text-2xl font-semibold uppercase">Professional <br />Mixing</h3>
							
							<svg width="16" height="8" viewBox="0 0 16 8" fill="none" xmlns="http://www.w3.org/2000/svg">
								<line x1="7" y1="1" x2="1" y2="1" stroke="#EC003F" stroke-opacity="0.88" stroke-width="2" stroke-linecap="round"/>
								<line x1="15" y1="7" x2="1" y2="7" stroke="#EC003F" stroke-opacity="0.88" stroke-width="2" stroke-linecap="round"/>
							</svg>
							
							<p class="text-gray-400 text-xl leading-relaxed font-light">
								I transform your raw tracks into a cohesive and impactful sound, ensuring every instrument and vocal shines in the right place.
							</p>
						</div>
						<img class="col-span-1 h-108 rounded-lg bg-zinc-900" src={placeholder2.src} alt="Placeholder" />
					</div>

					<div class="sticky top-28 z-30 h-120 w-full grid md:grid-cols-2 rounded-2xl p-6 bg-black">
						<div class="col-span-1 flex flex-col gap-8 rounded-3xl px-8 py-6">
							<h3 class="text-2xl font-semibold uppercase">High-Quality <br />Mastering</h3>
							
							<svg width="16" height="8" viewBox="0 0 16 8" fill="none" xmlns="http://www.w3.org/2000/svg">
								<line x1="7" y1="1" x2="1" y2="1" stroke="#EC003F" stroke-opacity="0.88" stroke-width="2" stroke-linecap="round"/>
								<line x1="15" y1="7" x2="1" y2="7" stroke="#EC003F" stroke-opacity="0.88" stroke-width="2" stroke-linecap="round"/>
							</svg>
							
							<p class="text-gray-400 text-xl leading-relaxed font-light">
								Mastering gives your music its final polish, enhancing clarity, balance, and loudness so it sounds professional on any platform.
							</p>
						</div>
						<img class="col-span-1 h-108 rounded-lg bg-zinc-900" src={placeholder3.src} alt="Placeholder" />
					</div>

					<div class="sticky top-32 z-40 h-120 w-full grid md:grid-cols-2 rounded-2xl p-6 bg-black">
						<div class="col-span-1 flex flex-col gap-8 rounded-3xl px-8 py-6">
							<h3 class="text-2xl font-semibold uppercase">Vocalist</h3>
							
							<svg width="16" height="8" viewBox="0 0 16 8" fill="none" xmlns="http://www.w3.org/2000/svg">
								<line x1="7" y1="1" x2="1" y2="1" stroke="#EC003F" stroke-opacity="0.88" stroke-width="2" stroke-linecap="round"/>
								<line x1="15" y1="7" x2="1" y2="7" stroke="#EC003F" stroke-opacity="0.88" stroke-width="2" stroke-linecap="round"/>
							</svg>
							
							<p class="text-gray-400 text-xl leading-relaxed font-light">
								I bring your lyrics to life, delivering emotive and dynamic vocal performances that connect with your audience.
							</p>

							<p class="text-gray-400 text-xl leading-relaxed font-light">
								I also team up with Denisse Ferrara, a talented vocalist, to offer a wider range of vocal styles and collaborations for your music projects.
							</p>
						</div>
						<img class="col-span-1 h-108 rounded-lg bg-zinc-900" src={placeholder4.src} alt="Placeholder" />
					</div>

					<div class="mt-12 text-center">
						<button class="px-5 py-4 bg-white text-black hover:bg-red-600 hover:text-white transition-all font-black text-lg rounded-2xl uppercase tracking-tighter">
							Ready to Transform Your Music?
						</button>
					</div>
				</div>
			</section>

			<!-- REACH / STATS SECTION -->
			<section id="productions" class="pt-24 pb-20 px-6 flex flex-col max-w-7xl mx-auto gap-16">
				<div class="grid md:grid-cols-3">
					<div class="col-span-1 flex flex-col gap-6">
						<span class="text-9xl">12</span>
						<span class="uppercase tracking-wider text-zinc-500">YEARS OF EXPERIENCE</span>
					</div>
					<div class="col-span-2 flex flex-col justify-end gap-8">
						<p class="text-3xl font-light tracking-wider uppercase text-white md:text-right">
							Crafting sonic landscapes. <br>Building cultural moments.
						</p>
						<p class="text-xl font-light tracking-wider uppercase text-white/60 md:text-right">
							Crafting sonic landscapes. <br>Building cultural moments.
						</p>
					</div>
				</div>

				<hr class="border-t border-white/5">

				<div class="grid md:grid-cols-3">
					<div class="col-span-1 flex flex-col gap-6">
						<!--
						RATIONAL
						Fiverr: 45
						Spotify: 73 rock 47 acoustic 19 others
						Total: 184
						-->
						<span class="text-8xl">184</span>
						<span class="uppercase tracking-wider text-zinc-500">PROJECTS COMPLETED</span>
					</div>
					<div class="col-span-1 flex flex-col gap-6">
						<span class="text-8xl">500K+</span>
						<span class="uppercase tracking-wider text-zinc-500">STREAMS</span>
					</div>
					<div class="col-span-1 flex flex-col gap-6">
						<!--
						RATIONAL
						Estimating a bit more than 10% of total streams as interactions (likes, comments, shares, saves)
						-->
						<span class="text-8xl">60K+</span>
						<span class="uppercase tracking-wider text-zinc-500">INTERACTIONS</span>
					</div>
				</div>
			</section>

			<!-- PORTFOLIO SECTION -->
			<section class="pt-12 pb-24 flex flex-col gap-16 max-w-7xl mx-auto min-h-screen">
				<h2 class="text-5xl font-light tracking-tight uppercase">
					Productions
				</h2>

				<div class="h-full grid grid-cols-2 gap-4">
					<img src={placeholder1.src} alt="Placeholder" class="col-span-1 h-full object-cover rounded-lg" />
					<div class="col-span-1 grid grid-cols-2 gap-4">
						<img src={placeholder2.src} alt="Placeholder" class="col-span-1 h-full object-cover rounded-lg" />
						<img src={placeholder3.src} alt="Placeholder" class="col-span-1 h-full object-cover rounded-lg" />
						<img src={placeholder4.src} alt="Placeholder" class="col-span-2 h-full object-cover rounded-lg" />
					</div>
				</div>

				<!-- <div class="text-center space-y-4 mb-12">
					<h2 class="text-4xl font-black tracking-tight">Selected Projects</h2>
					<p class="text-gray-400">Discover how quality mixing and mastering can make a difference.</p>
				</div> -->
				
				<div class="glass-card p-2 rounded-2xl overflow-hidden shadow-2xl shadow-red-900/10">
					<iframe
						data-testid="embed-spotify-iframe"
						style="border-radius:12px;border:none;"
						src="https://open.spotify.com/embed/artist/77SAbQybNSZmuluK93v8AO?utm_source=generator&theme=0"
						width="100%"
						height="352"
						allowfullscreen=""
						allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
						loading="lazy"
					>
					</iframe>
				</div>
			</section>

			<!-- CONTACT SECTION
			<section id="contact" class="py-24 px-6 max-w-7xl mx-auto">
				<div class="glass-card p-20 rounded-[3rem] text-center space-y-8 relative overflow-hidden">
					<div class="absolute top-0 right-0 p-8 opacity-5">
						<SendIcon class="w-40 h-40 text-red-600" />
					</div>
					
					<h2 class="text-4xl md:text-5xl font-black tracking-tighter">Let's Work <span class="text-rose-600">Together</span></h2>
					<p class="text-gray-400 max-w-2xl mx-auto leading-relaxed">
						To request a quote or ask questions, reach out directly via Instagram, Whatsapp or e-mail.
          				Let’s work together to make your ideas sound their best!
					</p>
					
					<div class="flex flex-wrap justify-center gap-4">
						<a href="#" class="px-6 py-3 bg-zinc-900 border border-white/10 rounded-xl flex items-center gap-2 hover:bg-zinc-800 transition-all font-semibold">
							<InstagramIcon class="w-5 h-5 text-[#FF0069]" />
							Instagram
						</a>
						<a href="#" class="px-6 py-3 bg-zinc-900 border border-white/10 rounded-xl flex items-center gap-2 hover:bg-zinc-800 transition-all font-semibold">
							<svg class="w-5 h-5 text-green-500" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M0 48L3.374 35.674C1.292 32.066 0.198 27.976 0.2 23.782C0.206 10.67 10.876 0 23.986 0C30.348 0.002 36.32 2.48 40.812 6.976C45.302 11.472 47.774 17.448 47.772 23.804C47.766 36.918 37.096 47.588 23.986 47.588C20.006 47.586 16.084 46.588 12.61 44.692L0 48ZM13.194 40.386C16.546 42.376 19.746 43.568 23.978 43.57C34.874 43.57 43.75 34.702 43.756 23.8C43.76 12.876 34.926 4.02 23.994 4.016C13.09 4.016 4.22 12.884 4.216 23.784C4.214 28.234 5.518 31.566 7.708 35.052L5.71 42.348L13.194 40.386ZM35.968 29.458C35.82 29.21 35.424 29.062 34.828 28.764C34.234 28.466 31.312 27.028 30.766 26.83C30.222 26.632 29.826 26.532 29.428 27.128C29.032 27.722 27.892 29.062 27.546 29.458C27.2 29.854 26.852 29.904 26.258 29.606C25.664 29.308 23.748 28.682 21.478 26.656C19.712 25.08 18.518 23.134 18.172 22.538C17.826 21.944 18.136 21.622 18.432 21.326C18.7 21.06 19.026 20.632 19.324 20.284C19.626 19.94 19.724 19.692 19.924 19.294C20.122 18.898 20.024 18.55 19.874 18.252C19.724 17.956 18.536 15.03 18.042 13.84C17.558 12.682 17.068 12.838 16.704 12.82L15.564 12.8C15.168 12.8 14.524 12.948 13.98 13.544C13.436 14.14 11.9 15.576 11.9 18.502C11.9 21.428 14.03 24.254 14.326 24.65C14.624 25.046 18.516 31.05 24.478 33.624C25.896 34.236 27.004 34.602 27.866 34.876C29.29 35.328 30.586 35.264 31.61 35.112C32.752 34.942 35.126 33.674 35.622 32.286C36.118 30.896 36.118 29.706 35.968 29.458Z" fill="currentColor" />
							</svg>
							WhatsApp
						</a>
						<a href="#" class="px-6 py-3 bg-zinc-900 border border-white/10 rounded-xl flex items-center gap-2 hover:bg-zinc-800 transition-all font-semibold">
							<MailIcon class="w-5 h-5 text-red-500" />
							Email
						</a>
					</div>
				</div>
			</section> -->

			<!-- SUPPORT SECTION -->
			<section class="py-24 px-6 max-w-3xl mx-auto text-center">
				<!-- Heart Icon -->
				<div class="flex justify-center mb-6 text-rose-500">
					<HeartIcon class="size-16" />
				</div>

				<h2 class="text-4xl font-bold mb-4">Support My Work</h2>
				<p class="text-gray-500 mb-8 leading-relaxed">
					If you enjoy my work and would like to support my musical journey, consider making a donation.
          			Your contribution helps me continue producing quality content and investing in new creative projects.
				</p>
				<div class="flex justify-center gap-6">
					<a href={DONATION_PATREON} class="flex items-center gap-2 text-sm font-bold text-gray-400 hover:text-white transition-colors">
						<svg class="size-6" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<title>Patreon</title>
							<path fill="white" d="M22.957 7.21c-.004-3.064-2.391-5.576-5.191-6.482-3.478-1.125-8.064-.962-11.384.604C2.357 3.231 1.093 7.391 1.046 11.54c-.039 3.411.302 12.396 5.369 12.46 3.765.047 4.326-4.804 6.068-7.141 1.24-1.662 2.836-2.132 4.801-2.618 3.376-.836 5.678-3.501 5.673-7.031Z"/>
						</svg>
						PATREON
					</a>
					<span class="text-zinc-800">|</span>
					<a href={DONATION_PAYPAL} class="flex items-center gap-2 text-sm font-bold text-gray-400 hover:text-white transition-colors">
						<svg class="size-6" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<title>PayPal</title>
							<path fill="white" d="M15.607 4.653H8.941L6.645 19.251H1.82L4.862 0h7.995c3.754 0 6.375 2.294 6.473 5.513-.648-.478-2.105-.86-3.722-.86m6.57 5.546c0 3.41-3.01 6.853-6.958 6.853h-2.493L11.595 24H6.74l1.845-11.538h3.592c4.208 0 7.346-3.634 7.153-6.949a5.24 5.24 0 0 1 2.848 4.686M9.653 5.546h6.408c.907 0 1.942.222 2.363.541-.195 2.741-2.655 5.483-6.441 5.483H8.714Z"/>
						</svg>
						PAYPAL
					</a>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>
