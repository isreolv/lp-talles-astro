---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import {
	SITE_DESCRIPTION,
	SITE_TITLE,
	CONTACT_WHATSAPP,
	SOCIAL_INSTAGRAM,
	SOCIAL_YOUTUBE,
	SOCIAL_TIKTOK,
	SOCIAL_YOUTUBE_MUSIC,
	SOCIAL_SPOTIFY,
	SOCIAL_DEEZER,
	SOCIAL_APPLE_MUSIC,
	SOCIAL_AMAZON_MUSIC,
	SOCIAL_AIRBIT,
	SOCIAL_FIVERR,
} from '../consts';

import AudioLinesIcon from '@lucide/astro/icons/audio-lines';
import tallesHeroSvg from '../assets/tcbrand.svg';

import tallesPic from '../assets/talles.webp';
import tallesProduction from '../assets/production.png';
import tallesMnm from '../assets/mnm.png';
import tallesVocals from '../assets/vocals.png';
import coverSong1 from '../assets/same-mistake.png'
import coverSong2 from '../assets/fate-of-ophelia.png'
import coverSong3 from '../assets/game-of-thrones.png'
import coverSong4 from '../assets/wicked-game.png'
import Waveform from '../components/icons/Waveform.astro';
import { ArrowRight } from '@lucide/astro';


---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="selection:bg-red-600 selection:text-white antialiased">
		<Header />

		<main>
			<!-- HERO SECTION -->
			<section id="home" class="hero-bg">
				<div class="relative flex flex-col mx-auto px-6 xl:px-0 py-16 max-w-7xl h-screen">
					<div class="flex flex-col justify-center items-center gap-8 h-full">
						<p class="top-56 z-0 absolute font-gothic md:text-[9rem] text-xl tracking-widest hero-title">
							Talles Cattarin
						</p>

						<div class="inline-flex z-10 justify-center items-center space-x-4 bg-zinc-950 px-3 py-2 border border-[#1C1C1C] rounded-[40px] text-white/80">
							<AudioLinesIcon class="w-5 h-5 text-red-500" />
							<p class="hidden md:block">Music Producer, Singer and Audio Engineer</p>
							<p class="md:hidden">Musician and Music Producer</p>
						</div>

						<img src={tallesHeroSvg.src} class="z-10 mt-4 w-full max-w-2xl -rotate-2 hover:-rotate-1 transition-transform duration-300" alt="Talles Cattarin" />

						<Waveform />
					</div>

					<div class="z-10 flex md:flex-row flex-col-reverse md:justify-between items-end gap-4 w-full">
						<p class="z-10 max-w-2xl font-light text-gray-400 text-xs md:text-sm uppercase leading-relaxed tracking-wide">
							Crafting sonic  · Building cultural
						</p>
						<div class="flex flex-col items-end gap-4">
							<a href="#studio" class="inline-flex items-center gap-2 bg-[#EC003F] hover:brightness-110 px-4 py-2.5 rounded-4xl transition-all hover:cursor-pointer">
								<svg width="12" height="14" viewBox="0 0 12 14" fill="none" xmlns="http://www.w3.org/2000/svg">
									<path d="M11.394 7.79602L1.8495 13.334C1.0395 13.8035 0 13.235 0 12.2885V1.21252C0 0.267522 1.038 -0.302478 1.8495 0.168522L11.394 5.70652C11.5783 5.81171 11.7314 5.96375 11.8379 6.14723C11.9445 6.33071 12.0006 6.53911 12.0006 6.75127C12.0006 6.96344 11.9445 7.17183 11.8379 7.35531C11.7314 7.53879 11.5783 7.69084 11.394 7.79602Z" fill="white"/>
								</svg>
								<span class="uppercase">Listen to my Latest Work</span>
							</a>
							<a href="#contact" class="inline-flex items-center gap-2 hover:brightness-90 px-4 py-2.5 border border-[#EC003F] rounded-4xl text-[#EC003F] hover:cursor-pointer">
								<span class="font-normal uppercase">Book a Session</span>
								<ArrowRight	class="w-4 h-4" />
							</a>
						</div>
					</div>
				</div>
			</section>

			<!-- ABOUT SECTION -->
			<section id="about" class="flex flex-col bg-zinc-950 px-6 xl:px-0 w-full min-h-screen">
				<div class="flex md:flex-row flex-col md:justify-between items-center gap-10 md:gap-0 mx-auto py-16 md:py-12 w-full max-w-7xl">
					<div class="inline-flex items-center gap-4">
						<span>KEEP EXPLORING</span>
						<AudioLinesIcon class="w-5 h-5 text-red-500" />
					</div>
					<div class="flex flex-col items-center md:items-end">
						<span class="text-zinc-500">RECORDED LIVE FROM</span>
						<span>25°25'S · 49°16'W — CURITIBA</span>
					</div>
				</div>

				<hr class="border-white/5 border-t">

				<div class="inline-flex items-center gap-4 mx-auto py-12 lg:py-16 w-full max-w-7xl">
					<span class="text-red-500 text-5xl">“</span>
					<span class="text-zinc-500">FIRST-PERSON NOTES</span>
				</div>

				<div class="relative gap-12 lg:gap-8 grid lg:grid-cols-3 mx-auto pb-12 max-w-7xl">
					<div class="z-10 flex flex-col lg:justify-between gap-12 lg:gap-0 order-2 lg:order-1 col-span-3 lg:col-span-2">
						<p class="font-medium md:text-[2.75rem] text-4xl tracking-wide">
							I don't chase trends. I chase <span class="text-red-500 italic">the song</span> that a listener won't skip — the one that makes them sit still for three minutes.
						</p>

						<span>
							<div class="bg-red-500 rounded w-12 h-0.5"></div>
							<p class="mt-6 lg:max-w-xl font-light text-zinc-400 text-xl">
								I was fourteen when I bootlegged my first mix on a cracked DAW. Twelve years later, the room is bigger, the monitors are better, the question hasn't changed: does this song earn its length?
							</p>
						</span>

						<div class="flex flex-wrap justify-center lg:justify-start items-center self-center lg:self-start gap-3 lg:max-w-lg max-w-xl">
							<a href={SOCIAL_INSTAGRAM} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
								Instagram
							</a>
							<a href={SOCIAL_YOUTUBE} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
								YouTube
							</a>
							<a href={SOCIAL_TIKTOK} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
								TikTok
							</a>
							<a href={SOCIAL_SPOTIFY} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
								Spotify
							</a>
							<a href={SOCIAL_DEEZER} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
								Deezer
							</a>
							<a href={SOCIAL_YOUTUBE_MUSIC} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
								Youtube Music
							</a>
							<a href={SOCIAL_APPLE_MUSIC} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
								Apple Music
							</a>
							<a href={SOCIAL_AMAZON_MUSIC} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
								Amazon Music
							</a>
							<a href={SOCIAL_AIRBIT} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
								Airbit
							</a>
							<a href={SOCIAL_FIVERR} target="_blank" class="font-light text-zinc-600 lg:text-xs text-sm uppercase tracking-widest">
								Fiverr
							</a>
						</div>
					</div>

					<div class="z-10 flex flex-col lg:justify-between gap-8 lg:gap-0 order-1 lg:order-2 col-span-3 lg:col-span-1 bg-[#121212]/40 p-8 border border-[#202020]/20 rounded-xl h-auto lg:h-134">
						<img src={tallesPic.src} alt="Talles Cattarin" class="col-span-1 shadow-md border border-[#202020]/80 rounded-md h-auto lg:h-83 object-cover" />

						<div class="flex flex-col gap-2">
							<span class="font-light text-red-500 text-base tracking-wide">THE ARTIST</span>
							<span class="mt-1.5 text-3xl tracking-wider">Talles Cattarin</span>
							<span class="text-zinc-500 text-sm">Music producer, singer and audio engineer</span>
						</div>
					</div>
				</div>
			</section>

			<!-- SERVICES SECTION -->
			<section id="services" class="flex flex-col bg-zinc-950 pt-22">
				<div class="space-y-2 md:space-y-4 mb-20 px-6 xl:px-0 text-center">
					<h2 class="font-medium text-5xl md:text-6xl tracking-normal">
						Three services.
					</h2>
					<p class="font-medium text-3xl md:text-6xl tracking-normal">
						Each done properly.
					</p>
					<p class="mt-10 text-zinc-500 uppercase text-balance">Nothing rushed. Typical turnaround: 5–7 days.</p>
				</div>

				<div class="bg-[#0B0B0B] py-10 border-white/4 border-x-8 border-y">
					<div class="place-items-center grid lg:grid-cols-2 mx-auto px-6 xl:px-0 py-4 rounded-2xl w-full max-w-7xl">
						<div class="flex flex-col gap-8 lg:order-1 col-span-1 lg:py-6 pb-8 rounded-3xl w-full">
							<h3 class="flex flex-col gap-2">
								<span class="font-light text-red-500 uppercase tracking-wider">Music</span>
								<span class="font-semibold text-2xl">Production</span>
							</h3>
							
							<p class="lg:max-w-sm font-light text-zinc-300 lg:text-lg text-xl leading-relaxed">
								I create and shape your music from concept to final product, ensuring every element is polished and impactful.
							</p>

							<a href="#contact" class="inline-flex items-center gap-2 text-zinc-500 text-sm uppercase">
								Learn More
								<ArrowRight class="w-4 h-4" />
							</a>
						</div>
						<img class="lg:order-2 col-span-1 bg-zinc-900 rounded-lg lg:w-auto h-auto lg:max-h-80" src={tallesProduction.src} alt="My studio! Showing two monitors, music instruments and all." />
					</div>
				</div>

				<div class="bg-[#0B0B0B] py-10 border-white/4 border-x-8 border-y">
					<div class="place-items-center grid lg:grid-cols-2 mx-auto px-6 xl:px-0 py-4 rounded-2xl w-full max-w-7xl">
						<div class="flex flex-col gap-8 lg:order-2 col-span-1 lg:py-6 pb-8 lg:pl-8 rounded-3xl w-full">
							<h3 class="flex flex-col gap-2">
								<span class="font-light text-red-500 uppercase tracking-wider">Professional</span>
								<span class="font-semibold text-2xl">Mixing and Mastering</span>
							</h3>
							
							<p class="lg:max-w-lg font-light text-zinc-300 lg:text-lg text-xl leading-relaxed">
								I transform your raw tracks into a cohesive and impactful sound, balancing every element so 
								each instrument and vocal sits perfectly in the mix—resulting in a polished,
								professional sound that translates well across any platform.
							</p>

							<a href="#contact" class="inline-flex items-center gap-2 text-zinc-500 text-sm uppercase">
								Learn More
								<ArrowRight class="w-4 h-4" />
							</a>
						</div>
						<img class="lg:order-1 col-span-1 bg-zinc-900 rounded-lg lg:w-auto h-auto lg:max-h-80" src={tallesMnm.src} alt="Me doing a nice mix and master." />
					</div>
				</div>

				<div class="bg-[#0B0B0B] py-10 border-white/4 border-x-8 border-y">
					<div class="place-items-center grid lg:grid-cols-2 mx-auto px-6 xl:px-0 py-4 rounded-2xl w-full max-w-7xl">
						<div class="flex flex-col lg:order-1 col-span-1 lg:py-6 pb-8 rounded-3xl w-full">
							<h3 class="flex flex-col gap-2">
								<span class="font-light text-red-500 uppercase tracking-wider">Solo or duet</span>
								<span class="font-semibold text-2xl">Vocals</span>
							</h3>
							
							<p class="mt-8 lg:max-w-lg font-light text-zinc-300 lg:text-lg text-xl leading-relaxed">
								I bring your lyrics to life, delivering emotive and dynamic vocal performances that connect with your audience.
							</p>

							<p class="mt-2 lg:max-w-lg font-light text-zinc-300 lg:text-lg text-xl leading-relaxed">
								I also team up with Denisse Ferrara, a talented vocalist, to offer a wider range of vocal styles and collaborations for your music projects.
							</p>

							<a href="#contact" class="inline-flex items-center gap-2 mt-8 text-zinc-500 text-sm uppercase">
								Learn More
								<ArrowRight class="w-4 h-4" />
							</a>
						</div>
						<img class="lg:order-2 col-span-1 bg-zinc-900 rounded-lg lg:w-auto h-auto lg:max-h-80" src={tallesVocals.src} alt="Myself singing at Hard Rock Cafe in Curitiba" />
					</div>
				</div>
			</section>

			<!-- REACH / STATS SECTION -->
			<section id="studio" class="flex flex-col gap-16 mx-auto px-6 pt-32 pb-20 max-w-7xl">
				<h2 class="font-medium text-5xl text-center md:text-start tracking-normal">
					Studio, live.
				</h2>

				<div class="gap-12 lg:gap-0 grid grid-cols-3">
					<div class="flex flex-col items-center lg:items-start gap-6 col-span-3 lg:col-span-1">
						<span class="text-9xl align-middle">
							<span data-counter data-value="10">10</span><span class="text-red-500 text-7xl">+</span>
						</span>
						<span class="text-zinc-500 uppercase tracking-wider">YEARS OF EXPERIENCE</span>
					</div>
					<div class="flex flex-col justify-end gap-8 col-span-3 lg:col-span-2">
						<p class="font-light text-white text-3xl text-center lg:text-right uppercase tracking-wider">
							Crafting sonic landscapes. <br>Building cultural moments.
						</p>
						<p class="hidden lg:block font-light text-white/60 text-xl lg:text-right uppercase tracking-wider">
							Crafting sonic landscapes. <br>Building cultural moments.
						</p>
					</div>
				</div>

				<hr class="border-white/5 border-t">

				<div class="gap-12 lg:gap-0 grid grid-cols-3">
					<div class="flex flex-col items-center lg:items-start gap-6 col-span-3 lg:col-span-1">
						<span class="text-8xl">
							<span data-counter data-value="185">185</span>
						</span>
						<span class="text-zinc-500 uppercase tracking-wider">PROJECTS COMPLETED</span>
					</div>
					<div class="flex flex-col items-center gap-6 col-span-3 lg:col-span-1">
						<span class="text-8xl">
							<span data-counter data-value="500">500</span>K<span class="text-red-500 text-7xl">+</span>
						</span>
						<span class="text-zinc-500 uppercase tracking-wider">STREAMS</span>
					</div>
					<div class="flex flex-col items-center lg:items-end gap-6 col-span-3 lg:col-span-1">
						<span class="text-8xl">
							<span data-counter data-value="60">60</span>K<span class="text-red-500 text-7xl">+</span>
						</span>
						<span class="text-zinc-500 uppercase tracking-wider">INTERACTIONS</span>
					</div>
				</div>
			</section>
			<script>
				function initCounters() {
					const counters = document.querySelectorAll('[data-counter]');
					
					counters.forEach(counter => counter.textContent = '0');

					const animateCounter = (el: HTMLElement, end: number) => {
						let startTimestamp: number | null = null;
						const start = 0;
						
						// DYNAMIC DURATION: Small numbers finish faster so they don't stutter.
						// E.g., 10 will take 1 second. 500 will hit the 2.5-second cap.
						const duration = Math.min(2500, Math.max(1500, end * 20)); 
						
						const step = (timestamp: number) => {
							if (!startTimestamp) startTimestamp = timestamp;
							
							const progress = Math.min((timestamp - startTimestamp) / duration, 1);
							
							// EXPONENTIAL EASE OUT: Starts super fast, glides to a stop smoothly.
							const easeOutExpo = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
							
							el.textContent = Math.floor(easeOutExpo * (end - start) + start).toString();
							
							if (progress < 1) {
								window.requestAnimationFrame(step);
							} else {
								el.textContent = end.toString(); 
							}
						};
						
						window.requestAnimationFrame(step);
					};

					const observerOptions = {
						root: null,
						rootMargin: '0px',
						threshold: 0.5 
					};

					const observer = new IntersectionObserver((entries, observer) => {
						entries.forEach(entry => {
							if (entry.isIntersecting) {
							const target = entry.target as HTMLElement;
							const targetValue = parseInt(target.getAttribute('data-value')!, 10);
							
							animateCounter(target, targetValue);
							observer.unobserve(target);
							}
						});
					}, observerOptions);

					counters.forEach(counter => {
						observer.observe(counter);
					});
				}

				initCounters();
				document.addEventListener('astro:page-load', initCounters);
				</script>

			<!-- PORTFOLIO SECTION -->
			<section class="flex flex-col mx-auto px-6 xl:px-0 pt-24 pb-8 md:pb-24 max-w-7xl">
				<div class="md:inline-flex justify-between items-center">
					<h2 class="font-medium text-5xl tracking-normal">
						From the studio.
					</h2>
					<a href={SOCIAL_YOUTUBE} target="_blank" class="hidden md:inline-flex items-center gap-1.5 font-light text-red-500 hover:cursor-pointer">
						SEE MORE
						<ArrowRight class="inline-block w-4 h-4" />
					</a>
				</div>

				<div class="gap-4 grid grid-cols-1 lg:grid-cols-4 lg:grid-rows-2 mt-16 lg:h-150 min-h-150">
    
					<a href="https://www.youtube.com/watch?v=wvpaZrfDtpk" target="_blank" rel="noopener noreferrer" class="group relative flex flex-col justify-between items-start lg:col-span-2 lg:row-span-2 bg-[#121212] p-6 border border-[#202020] rounded-lg h-full min-h-122 lg:min-h-0 overflow-hidden hover:cursor-pointer">
						<img src={coverSong4.src} alt="Wicked Game Cover" class="z-0 absolute inset-0 opacity-60 group-hover:opacity-80 w-full h-full object-cover transition-opacity duration-300" />
						<div class="z-10 absolute inset-0 bg-linear-to-t from-[#121212] via-[#121212]/20 md:via-[#121212]/30 to-transparent"></div>
						
						<div class="z-20 relative bg-black/20 backdrop-blur-sm p-2 border border-zinc-400/50 rounded-md text-zinc-300 text-sm">
							Acoustic Cover · 2025
						</div>
						<div class="z-20 relative flex flex-col gap-1 text-white">
							<span class="font-medium text-4xl tracking-wide">Wicked Game</span>
							<span class="font-light text-zinc-300 text-base tracking-wide">Chris Isaak (1989)</span>
						</div>
					</a>

					<a href="https://youtu.be/d99Z5Z111Vw" target="_blank" rel="noopener noreferrer" class="group relative flex flex-col justify-between items-start lg:col-span-1 bg-[#121212] p-4 border border-[#202020] rounded-lg h-full min-h-62.5 lg:min-h-0 overflow-hidden hover:cursor-pointer">
						<img src={coverSong3.src} alt="Game of Thrones Cover" class="z-0 absolute inset-0 opacity-60 group-hover:opacity-80 w-full h-full object-cover transition-opacity duration-300" />
						<div class="z-10 absolute inset-0 bg-linear-to-t from-[#121212] via-[#121212]/20 md:via-[#121212]/30 to-transparent"></div>
						
						<div class="z-20 relative bg-black/20 backdrop-blur-sm p-2 border border-zinc-400/50 rounded-md text-zinc-300 text-sm">
							Rock Cover · 2026
						</div>
						<div class="z-20 relative flex flex-col gap-1 text-white">
							<span class="font-medium text-2xl tracking-wide">Game of Thrones</span>
							<span class="font-light text-zinc-300 text-sm tracking-wide">Ramin Djawadi (2011)</span>
						</div>
					</a>
					
					<a href="https://www.youtube.com/watch?v=tD_h_UhwV80" target="_blank" rel="noopener noreferrer" class="group relative flex flex-col justify-between items-start lg:col-span-1 bg-[#121212] p-4 border border-[#202020] rounded-lg h-full min-h-62.5 lg:min-h-0 overflow-hidden hover:cursor-pointer">
						<img src={coverSong2.src} alt="Fate of Ophelia Cover" class="z-0 absolute inset-0 opacity-60 group-hover:opacity-80 w-full h-full object-cover transition-opacity duration-300" />
						<div class="z-10 absolute inset-0 bg-linear-to-t from-[#121212] via-[#121212]/20 md:via-[#121212]/30 to-transparent"></div>
						
						<div class="z-20 relative bg-black/20 backdrop-blur-sm p-2 border border-zinc-400/50 rounded-md text-zinc-300 text-sm">
							Rock Cover · 2026
						</div>
						<div class="z-20 relative flex flex-col gap-1 text-white">
							<span class="font-medium text-2xl tracking-wide">Fate of Ophelia</span>
							<span class="font-light text-zinc-300 text-sm tracking-wide">Taylor Swift (2025)</span>
						</div>
					</a>

					<a href="https://youtu.be/IdwOPAU4gQs" target="_blank" rel="noopener noreferrer" class="group relative flex flex-col justify-between items-start lg:col-span-2 bg-[#121212] p-4 border border-[#202020] rounded-lg h-full min-h-62.5 lg:min-h-0 overflow-hidden hover:cursor-pointer">
						<img src={coverSong1.src} alt="Same Mistake Cover" class="z-0 absolute inset-0 opacity-60 group-hover:opacity-80 w-full h-full object-cover transition-opacity duration-300" />
						<div class="z-10 absolute inset-0 bg-linear-to-t from-[#121212] via-[#121212]/20 md:via-[#121212]/30 to-transparent"></div>
						
						<div class="z-20 relative bg-black/20 backdrop-blur-sm p-2 border border-zinc-400/50 rounded-md text-zinc-300 text-sm">
							Rock Cover · 2026
						</div>
						<div class="z-20 relative flex flex-col gap-1 text-shadow text-white">
							<span class="font-medium text-2xl tracking-wide">Same Mistake</span>
							<span class="font-light text-zinc-300 text-sm tracking-wide">James Blunt (2007)</span>
						</div>
					</a>

				</div>

				<a href={SOCIAL_YOUTUBE} target="_blank" class="md:hidden items-center self-center gap-1.5 mt-8 font-light text-red-500 hover:cursor-pointer">
					SEE MORE
					<ArrowRight class="inline-block w-4 h-4" />
				</a>
			</section>

